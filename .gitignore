# Env
.env.local
.env.*.local

# Worktrees
.worktrees/
.claude/

# Rust
target/
# Cargo.lock IS committed: orca is a binary application, so the lockfile must be
# tracked for reproducible CI. Leaving it ignored let CI resolve dependencies
# fresh on every run — an upstream `time 0.3.52` release then broke `cookie
# 0.18.1` (E0061) even though local builds pinned a working `time 0.3.47`.

# Node / JS
node_modules/
dist/
build/
coverage/
*.tsbuildinfo

# Svelte / Vite
.svelte-kit/

# Gradle / Kotlin
.gradle/
!gradle/wrapper/gradle-wrapper.jar
dist-release/
dist-*/

