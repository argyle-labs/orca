    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "storybook": "^10.4.6",
    "svelte-check": "^4.6.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.7"
