# Auto-load orca secrets from 1Password when entering this directory.
# Requires: direnv (brew install direnv) + op (1Password CLI, signed in)
# Uses $OP_ACCOUNT (your personal 1Password account, set in ~/.zshrc)
#
# GITHUB_TOKEN is intentionally NOT loaded here — daily GitHub auth uses
# `gh auth login` (OAuth → keyring). Scripts that need a token call
# `gh auth token` on demand. Loading a static PAT from 1P used to override
# the keyring with a stale value and break `gh auth login` itself.
if command -v op >/dev/null 2>&1 && [ -n "${OP_ACCOUNT:-}" ]; then
  eval "$(op run --account "$OP_ACCOUNT" \
    --env-file "$PWD/.env.orca.tpl" --no-masking -- env 2>/dev/null \
    | grep -E '^(ANTHROPIC_API_KEY|ATLASSIAN_TOKEN)=' \
    | sed 's/^/export /')" 2>/dev/null || true
fi

export ORCA_LOG=debug

# Machine-private overrides — gitignored, never committed. Put deployment
# secrets here, e.g. the real router IP the OPNsense bash-guard should block:
#   export ORCA_ROUTER_GUARD_IP=<your.router.ip>
[ -f "$PWD/.env.orca.local" ] && source "$PWD/.env.orca.local"
